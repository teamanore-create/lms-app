# Database Connection
# Format: postgresql://[user[:password]@][netloc][:port][/dbname][?param1=value1&...]
DATABASE_URL="postgresql://user:password@localhost:5432/bim_academy"

# JWT Secret for signing authentication tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Better Auth Secret (if using Better Auth)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-here-min-32-chars"

# Better Auth URL (optional)
# Will auto-detect from VERCEL_URL if not set
# BETTER_AUTH_URL="http://localhost:3000"

# SMTP email settings for OTP delivery
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
SMTP_FROM="BIM Training <noreply@yourdomain.com>"

# Node Environment
NODE_ENV="development"
